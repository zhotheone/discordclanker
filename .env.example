DISCORD_TOKEN=
DISCORD_CLIENT_ID=

REMOTE_USER="user"
REMOTE_HOST="11.11.11.111"
REMOTE_DIR="~/docker/discordclanker"

LOG_LEVEL=DEBUG

# Optional: path to Netscape-format cookies file for authenticated YouTube playback
# COOKIES_PATH=www.youtube.com_cookies.txt

# Optional: proxy for yt-dlp requests (http://, https://, socks5://)
# YTDLP_PROXY=socks5://127.0.0.1:1080

# Set to false during local dev to avoid Discord's global sync rate limit
SYNC_COMMANDS=true

